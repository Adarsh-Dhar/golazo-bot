# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- TxLINE ---
# "mainnet" or "devnet" -- must be consistent: RPC, program ID, TxL mint,
# guest JWT, and activation endpoint all come from the matching network
# table in src/config.ts. Use devnet while developing.
TXLINE_NETWORK=devnet

# Path to a local Solana keypair JSON file (array of numbers format, e.g.
# from `solana-keygen new`). This wallet needs a small amount of SOL for
# gas to submit the on-chain `subscribe` transaction -- even though the
# free-tier subscription itself costs 0 TxL. Get free devnet SOL with:
#   solana airdrop 1 <your-pubkey> --url devnet
# or https://faucet.solana.com
SOLANA_KEYPAIR_PATH=./solana-keypair.json

# Service level 1 = World Cup + Int'l Friendlies, 60s delay, free.
# Service level 12 = same, real-time, free -- documented as mainnet only;
# devnet currently only documents service level 1.
TXLINE_SERVICE_LEVEL_ID=1
TXLINE_DURATION_WEEKS=4
TXLINE_SELECTED_LEAGUES=

# --- Optional: LLM for conversational /ask ---
OPENAI_API_KEY=
# or ANTHROPIC_API_KEY=
