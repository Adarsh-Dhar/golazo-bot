# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- TxLINE ---
# "mainnet" or "devnet" — must match everywhere below
TXLINE_NETWORK=devnet

# Path to a local Solana keypair JSON file (e.g. from `solana-keygen new`)
# Used only to sign the free-tier activation message — no funds are moved
# for the World Cup / Int'l Friendlies free service levels.
SOLANA_KEYPAIR_PATH=./solana-devnet-keypair.json

# League/service selection — see /documentation/worldcup for the exact
# free service level IDs (1 or 12) at integration time.
TXLINE_SERVICE_LEVEL_ID=1
TXLINE_SELECTED_LEAGUES=

# --- Optional: LLM for conversational /ask ---
OPENAI_API_KEY=
# or ANTHROPIC_API_KEY=
